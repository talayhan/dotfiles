#!/usr/bin/env bash
#
# Compose a dotbot manifest for the current platform and run it.
#
#   ./install                      detect the platform automatically
#   ./install -p macos             force a platform
#   ./install -n                   print the composed manifest and exit
#   ./install -c custom.conf.yaml  bypass composition, run one manifest verbatim
#   ./install -w                   walk through an interactive wizard first
#
# Any remaining arguments are forwarded to dotbot (e.g. --verbose, --only link).

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
CONFIG_DIR="${BASEDIR}/install.d"

PLATFORM=""
EXPLICIT_CONFIG=""
DRY_RUN=0
WIZARD=0
DOTBOT_ARGS=()

usage() {
    sed -n '2,12p' "${BASH_SOURCE[0]}" | sed 's/^#\s\?//'
}

while [ $# -gt 0 ]; do
    case "${1}" in
        -p|--platform)
            PLATFORM="${2}"
            shift 2
            ;;
        -c|--config-file)
            EXPLICIT_CONFIG="${2}"
            shift 2
            ;;
        -n|--dry-run)
            DRY_RUN=1
            shift
            ;;
        -w|--wizard)
            WIZARD=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            DOTBOT_ARGS+=("${1}")
            shift
            ;;
    esac
done

if [ -n "${PLATFORM}" ]; then
    EXPLICIT_P=1
else
    EXPLICIT_P=0
fi

# Legacy entry point: ./install -c install_ubuntu.conf.yaml still works, and is
# translated into the equivalent composed run.
if [ -n "${EXPLICIT_CONFIG}" ]; then
    legacy_name="$(basename "${EXPLICIT_CONFIG}")"
    case "${legacy_name}" in
        install_*.conf.yaml)
            PLATFORM="${legacy_name#install_}"
            PLATFORM="${PLATFORM%.conf.yaml}"
            echo "[i] '${EXPLICIT_CONFIG}' is deprecated; using './install -p ${PLATFORM}'." >&2
            EXPLICIT_CONFIG=""
            ;;
    esac
fi

if [ -z "${PLATFORM}" ] && [ -z "${EXPLICIT_CONFIG}" ]; then
    # shellcheck source=user_specific/os.sh
    . "${BASEDIR}/user_specific/os.sh"
    PLATFORM="${DOTFILES_OS}"
    if [ "${PLATFORM}" = "unknown" ]; then
        echo "[-] Could not detect the platform. Pass one explicitly:" >&2
        echo "    ./install -p <ubuntu|manjaro|centos7|macos>" >&2
        exit 1
    fi
    echo "[+] Detected platform: ${PLATFORM}"
fi

# Interactive wizard: banner, platform pick (skipped if -p was explicit), and
# a preview of what the composed manifest will link, before anything runs.
# Bypassed entirely for the legacy -c path, which has no per-platform preview
# to show. Degrades gracefully -- same pattern as the private pconfigs
# submodule -- when cargo isn't available.
if [ "${WIZARD}" -eq 1 ] && [ -z "${EXPLICIT_CONFIG}" ]; then
    if ! command -v cargo >/dev/null 2>&1; then
        echo "[i] --wizard requires cargo; continuing without it" >&2
    else
        WIZARD_BIN="${BASEDIR}/wizard/target/release/dfwizard"
        if ! cargo build --release --manifest-path "${BASEDIR}/wizard/Cargo.toml" --quiet; then
            echo "[-] failed to build the install wizard" >&2
            exit 1
        fi

        WIZARD_PLATFORM_ARGS=()
        if [ "${EXPLICIT_P}" -eq 1 ]; then
            WIZARD_PLATFORM_ARGS=(--platform "${PLATFORM}")
        fi

        set +e
        WIZARD_OUT="$("${WIZARD_BIN}" --repo "${BASEDIR}" --default-platform "${PLATFORM}" "${WIZARD_PLATFORM_ARGS[@]}")"
        WIZARD_STATUS=$?
        set -e

        case "${WIZARD_STATUS}" in
            0)
                SELECTED="$(printf '%s\n' "${WIZARD_OUT}" | sed -n 's/^SELECTED_PLATFORM=//p')"
                [ -n "${SELECTED}" ] && PLATFORM="${SELECTED}"
                WIZARD_MANIFEST="$(printf '%s\n' "${WIZARD_OUT}" | sed -n 's/^MANIFEST_FILE=//p')"
                ;;
            2)
                echo "Cancelled." >&2
                exit 0
                ;;
            *)
                echo "[-] install wizard failed" >&2
                exit 1
                ;;
        esac
    fi
fi

if [ -n "${WIZARD_MANIFEST:-}" ]; then
    # The wizard already composed (and possibly trimmed, per the component
    # checklist) a manifest identical in shape to what the block below would
    # produce -- reuse it instead of re-composing from PARTS.
    COMPOSED="${WIZARD_MANIFEST}"
    CLEANUP="${COMPOSED}"
elif [ -n "${EXPLICIT_CONFIG}" ]; then
    COMPOSED="${EXPLICIT_CONFIG}"
    CLEANUP=""
else
    if [ ! -f "${CONFIG_DIR}/${PLATFORM}.conf.yaml" ]; then
        echo "[-] Unknown platform '${PLATFORM}'. Available:" >&2
        for f in "${CONFIG_DIR}"/*.conf.yaml; do
            name="$(basename "${f}" .conf.yaml)"
            case "${name}" in
                common|linux|post) continue ;;
            esac
            echo "    ${name}" >&2
        done
        exit 1
    fi

    # Each manifest is a top-level YAML list, so composition is concatenation.
    # Order matters: common defines the defaults, post runs last.
    PARTS=("${CONFIG_DIR}/common.conf.yaml")
    if [ "${PLATFORM}" != "macos" ]; then
        PARTS+=("${CONFIG_DIR}/linux.conf.yaml")
    fi
    PARTS+=("${CONFIG_DIR}/${PLATFORM}.conf.yaml" "${CONFIG_DIR}/post.conf.yaml")

    COMPOSED="$(mktemp "${TMPDIR:-/tmp}/dotfiles-${PLATFORM}-XXXXXX")"
    CLEANUP="${COMPOSED}"
    {
        echo "# Generated by ./install for platform: ${PLATFORM}"
        for part in "${PARTS[@]}"; do
            echo ""
            echo "# --- ${part##*/} ---"
            cat "${part}"
        done
    } > "${COMPOSED}"
fi

# shellcheck disable=SC2064
if [ -n "${CLEANUP}" ]; then
    trap "rm -f '${CLEANUP}'" EXIT
fi

if [ "${DRY_RUN}" -eq 1 ]; then
    cat "${COMPOSED}"
    exit 0
fi

cd "${BASEDIR}"
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${COMPOSED}" "${DOTBOT_ARGS[@]}"
